{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/impressum",
            "destination": "/impressum/index.html"
        },
        {
            "source": "/datenschutz",
            "destination": "/datenschutz/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}